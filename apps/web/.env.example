# Zero NPC Web - Environment variables (public, prefixed with NEXT_PUBLIC_)
# Copy to `.env.local` and customize.

# Base URL del API (sin trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=http://localhost:8000

# Clave publicable de Stripe (test mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Nombre comercial
NEXT_PUBLIC_APP_NAME=Zero NPC
