# ===========================================================================
# Zero NPC API - Environment variables
# Copy this file to `.env` and fill in local values. Never commit `.env`.
# ===========================================================================

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development
APP_PORT=8000
LOG_LEVEL=debug

# --- CORS ------------------------------------------------------------------
# Comma-separated origins. Use `*` only in development.
CORS_ORIGIN=http://localhost:3000

# --- PostgreSQL ------------------------------------------------------------
# Railway provides DATABASE_URL in production; locally use the parts below.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zero_npc_dev
DB_USER=zero_npc
DB_PASSWORD=zero_npc_dev_password
DB_SSL=false

# --- JWT -------------------------------------------------------------------
# Generate with: `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
JWT_ACCESS_SECRET=replace-me-with-a-strong-random-secret
JWT_REFRESH_SECRET=replace-me-with-a-different-strong-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# --- Bcrypt ----------------------------------------------------------------
BCRYPT_SALT_ROUNDS=12

# --- Password pepper --------------------------------------------------------
# Secret del servidor concatenado a la contraseña ANTES de bcrypt.
# Protege contra filtraciones de BD: sin el pepper los hashes no se crackean.
# Generar con: `openssl rand -base64 48`
PASSWORD_PEPPER=replace-me-with-openssl-rand-base64-48-output

# --- Cifrado de datos PII en reposo -----------------------------------------
# Clave AES-256 en base64 (32 bytes decodificados).
# Cifra fullName, addressLine1/2, postalCode, province, city en la tabla users.
# Generar con: `openssl rand -base64 32`
DATA_ENCRYPTION_KEY=replace-me-with-openssl-rand-base64-32-output

# --- Email -----------------------------------------------------------------
# Opción 1 (recomendada): Resend (HTTPS API)
#   Crea una API key en https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM="Zero NPC <onboarding@resend.dev>"

# Opción 2 (fallback): SMTP cualquiera
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- Stripe (test mode) ----------------------------------------------------
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_SUCCESS_URL=http://localhost:3000/checkout/success
STRIPE_CANCEL_URL=http://localhost:3000/checkout/cancel

# --- Uploads ---------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=8

# --- Rate limiting ---------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# --- Token mechanics -------------------------------------------------------
# Max daily charges granted by the "daily reset" job to a user.
TOKEN_DAILY_CHARGES=5
TOKEN_CHARGE_RESET_HOURS=24
